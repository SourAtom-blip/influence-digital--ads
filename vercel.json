{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://influence-digital-ads-production.up.railway.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://influence-digital-ads-production.up.railway.app/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
